{
  "manifest_version": 3,
  "name": "AI Video Translator PRO",
  "description": "Real-time subtitle translation and voice-over for video platforms.",
  "version": "2.0.0",
  "permissions": ["storage"],
  "host_permissions": [
    "<all_urls>",
    "https://translate.googleapis.com/*",
    "https://libretranslate.de/*",
    "https://api.openai.com/*"
  ],
  "background": {
    "service_worker": "background/background.js"
  },
  "action": {
    "default_title": "AI Video Translator PRO",
    "default_popup": "popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "utils/logger.js",
        "utils/dom.js",
        "services/state.js",
        "services/tts.js",
        "content/adapters/youtube.js",
        "content/adapters/udemy.js",
        "content/adapters/generic.js",
        "content/content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
